# Copy this file to .env and fill in your values

# ── Product ────────────────────────────────────────────────────────────────
TARGET_SIZE=4
CHECK_INTERVAL_MINUTES=15    # used only when running monitor.py (not GitHub Actions)

# ── Telegram notification (recommended) ───────────────────────────────────
# Setup:
#   1. Open Telegram and message @BotFather → /newbot → follow prompts
#   2. Copy the token it gives you into TELEGRAM_BOT_TOKEN
#   3. Message your new bot once (any text), then open:
#      https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#      and copy the "id" from result[0].message.chat.id into TELEGRAM_CHAT_ID
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=123456789:ABCDefgh...
TELEGRAM_CHAT_ID=987654321

# ── Browser mode ──────────────────────────────────────────────────────────
# auto      → cdp on Windows, playwright on Linux  (recommended)
# cdp       → launch real Chrome subprocess (best anti-bot bypass)
# playwright → use headless Playwright Chromium (for CI / servers)
BROWSER_MODE=auto

# ── Optional email notification ───────────────────────────────────────────
EMAIL_ENABLED=false
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_password   # Gmail App Password (not your main password)
EMAIL_RECEIVER=your_gmail@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
